# terraform code for Backend S3 


terraform {
   backend "s3" {
     bucket          =  "terraform-state-locking-Qa"
     key             =   "Qa/State-locking-Qa.tfstate"
     region          =   "ap-south-1"
     dynamodb_table  =   "db-table-lock"
     encrypt         =   true  
  }
}


# terraform for S3 using file lock 



terraform { 
   backend "s3"  {
      bucket          =    "State-locking-prod-22"
      key             =    "prod/locking.tfstate"
      region          =    "ap-south-1"
      use_lock_file   =    true                                  # only available in version 1.10 
      encrypt         =    true 
    }
 }



 

## ansible yaml to install apache 


--- 
- name:  Install and start the apache 
  hosts: webserver 
  become: yes 
  
  tasks: 
    - name: Install Apache 
       yum: 
        name:   httpd
        state:  present 
    
    - name:  Start the service
        service:
          name: httpd
          state: started 
          enabled: yes 
   


