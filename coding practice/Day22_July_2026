# Kubernetes for ReplicaSet 

apiversion:   apps/v1
kind:         ReplicaSet
metadata:     
  name:  backend-serviec-replicaset
  labels:
   env:   staging 
   app:   backend 

spec:  
  replicas:   5 
  selector:
    matchLabels:
     app:         backend-service
  
  template:    
    metadata:
      labels:
        app:     backend-service

    spec:
      containers:
       - name:   backend-service-pod
         image:  nginx:latest / backend-service:17.2    # image name gets changed according to the requirements
         ports: 
          - containerPort:  80  


